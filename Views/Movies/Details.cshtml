@model MovieRentalSystem.Models.Movie

@{
    ViewData["Title"] = "Movie Details";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h2>@Model.Title (@Model.Year)</h2>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Director:</dt>
                    <dd class="col-sm-8">@Model.Director</dd>

                    <dt class="col-sm-4">Year:</dt>
                    <dd class="col-sm-8">@Model.Year</dd>

                    <dt class="col-sm-4">Genre:</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-info">@Model.Genre</span>
                    </dd>

                    <dt class="col-sm-4">Price per Day:</dt>
                    <dd class="col-sm-8">@Model.PricePerDay.ToString("C")</dd>

                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsAvailable)
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Rented</span>
                        }
                    </dd>
                </dl>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mt-3">
                        <h5>Description:</h5>
                        <p>@Model.Description</p>
                    </div>
                }
            </div>

            <div class="col-md-6">
                <h5>Rental History</h5>
                @if (Model.Rentals.Any())
                {
                    <ul class="list-group">
                        @foreach (var rental in Model.Rentals.OrderByDescending(r => r.RentalDate).Take(5))
                        {
                            <li class="list-group-item">
                                <strong>@rental.RentalDate.ToString("dd/MM/yyyy")</strong>
                                @if (rental.IsReturned && rental.ReturnDate.HasValue)
                                {
                                    <span class="text-success"> - Returned @rental.ReturnDate.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else
                                {
                                    <span class="text-warning"> - Currently rented</span>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No rental history</p>
                }
            </div>
        </div>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>