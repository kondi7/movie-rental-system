@model MovieRentalSystem.Models.Movie

@{
    ViewData["Title"] = "Delete Movie";
}

<h1>Delete Movie</h1>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this movie?</h4>
</div>

<div class="card">
    <div class="card-header bg-danger text-white">
        <h3>@Model.Title</h3>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Director:</dt>
            <dd class="col-sm-9">@Model.Director</dd>

            <dt class="col-sm-3">Year:</dt>
            <dd class="col-sm-9">@Model.Year</dd>

            <dt class="col-sm-3">Genre:</dt>
            <dd class="col-sm-9">@Model.Genre</dd>

            <dt class="col-sm-3">Price per Day:</dt>
            <dd class="col-sm-9">@Model.PricePerDay.ToString("C")</dd>

            <dt class="col-sm-3">Status:</dt>
            <dd class="col-sm-9">
                @if (Model.IsAvailable)
                {
                    <span class="badge bg-success">Available</span>
                }
                else
                {
                    <span class="badge bg-danger">Rented</span>
                }
            </dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you absolutely sure?')">
        Confirm Delete
    </button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>