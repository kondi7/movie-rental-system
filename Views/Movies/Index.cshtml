@model IEnumerable<MovieRentalSystem.Models.Movie>

@{
    ViewData["Title"] = "Movies";
}

<div class="row mb-3">
    <div class="col-md-6">
        <h1>Movies</h1>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Movie
        </a>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <input type="text" id="searchBox" class="form-control" placeholder="Search movies...">
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover" id="moviesTable">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Director</th>
                <th>Year</th>
                <th>Genre</th>
                <th>Price/Day</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Director</td>
                    <td>@item.Year</td>
                    <td>
                        <span class="badge bg-info">@item.Genre</span>
                    </td>
                    <td>@item.PricePerDay.ToString("C")</td>
                    <td>
                        @if (item.IsAvailable)
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Rented</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        setupSearch('searchBox', 'moviesTable');
        countItems('Movies');
    </script>
}