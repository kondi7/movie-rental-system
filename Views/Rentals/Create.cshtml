@model MovieRentalSystem.Models.Rental

@{
    ViewData["Title"] = "New Rental";
}

<h1>Create New Rental</h1>

<hr/>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" id="rentalForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label class="control-label">Customer</label>
                <input type="text" id="customerSearch" class="form-control" placeholder="Type customer name..."
                       autocomplete="off"/>
                <ul id="customerSuggestions" class="list-group position-absolute z-3 w-100"
                    style="display:none; max-height:200px; overflow-y:auto;"></ul>
                <input type="hidden" id="CustomerId" name="CustomerId"/>
                <span asp-validation-for="CustomerId" class="text-danger"></span>
                <small id="customerSelected" class="text-success" style="display:none;">✓ Customer selected</small>
            </div>

            <div class="form-group mb-3 position-relative">
                <label class="control-label">Movie</label>
                <input type="text" id="movieSearch" class="form-control" placeholder="Type movie title..."
                       autocomplete="off"/>
                <ul id="movieSuggestions" class="list-group position-absolute z-3 w-100"
                    style="display:none; max-height:200px; overflow-y:auto;"></ul>
                <input type="hidden" id="MovieId" name="MovieId"/>
                <span asp-validation-for="MovieId" class="text-danger"></span>
                <small id="movieSelected" class="text-success" style="display:none;">✓ Movie selected</small>
            </div>

            <div class="alert alert-info">
                <strong>Note:</strong> The rental will start today. Price will be calculated when the movie is returned
                based on the number of days.
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Create Rental" class="btn btn-primary"/>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const customers = @Html.Raw(Json.Serialize(
                              ((IEnumerable<SelectListItem>)ViewBag.CustomerId)
                              .Where(x => x.Value != "")
                              .Select(x => new { id = x.Value, name = x.Text })
                          ));

        const movies = @Html.Raw(Json.Serialize(
                           ((IEnumerable<SelectListItem>)ViewBag.MovieId)
                           .Where(x => x.Value != "")
                           .Select(x => new { id = x.Value, name = x.Text })
                       ));

        function setupAutocomplete({inputId, suggestionsId, hiddenId, confirmId, data}) {
            const input = document.getElementById(inputId);
            const suggestions = document.getElementById(suggestionsId);
            const hidden = document.getElementById(hiddenId);
            const confirm = document.getElementById(confirmId);

            input.addEventListener('input', () => {
                const query = input.value.trim().toLowerCase();
                hidden.value = '';               // clear previous selection
                confirm.style.display = 'none';

                if (query.length < 1) {
                    suggestions.style.display = 'none';
                    return;
                }

                const matches = data.filter(d => d.name.toLowerCase().includes(query)).slice(0, 10);

                if (matches.length === 0) {
                    suggestions.style.display = 'none';
                    return;
                }

                suggestions.innerHTML = matches.map(m =>
                    `<li class="list-group-item list-group-item-action" style="cursor:pointer"
                     data-id="${m.id}" data-name="${m.name}">${m.name}</li>`
                ).join('');
                suggestions.style.display = 'block';
            });

            suggestions.addEventListener('click', e => {
                const li = e.target.closest('li[data-id]');
                if (!li) return;
                input.value = li.dataset.name;
                hidden.value = li.dataset.id;
                suggestions.style.display = 'none';
                confirm.style.display = 'inline';
            });

            document.addEventListener('click', e => {
                if (!input.contains(e.target) && !suggestions.contains(e.target)) {
                    suggestions.style.display = 'none';
                }
            });
        }

        setupAutocomplete({
            inputId: 'customerSearch', suggestionsId: 'customerSuggestions',
            hiddenId: 'CustomerId', confirmId: 'customerSelected',
            data: customers
        });

        setupAutocomplete({
            inputId: 'movieSearch', suggestionsId: 'movieSuggestions',
            hiddenId: 'MovieId', confirmId: 'movieSelected',
            data: movies
        });

        document.getElementById('rentalForm').addEventListener('submit', e => {
            if (!document.getElementById('CustomerId').value) {
                alert('Please select a customer from the suggestions.');
                e.preventDefault();
                return;
            }
            if (!document.getElementById('MovieId').value) {
                alert('Please select a movie from the suggestions.');
                e.preventDefault();
            }
        });
    </script>
}