@model MovieRentalSystem.Models.Rental

@{
    ViewData["Title"] = "Return Movie";
    var days = (DateTime.Now - Model.RentalDate).Days;
    if (days < 1) days = 1;
    var estimatedPrice = Model.Movie.PricePerDay * days;
}

<h1>Return Movie</h1>

<div class="alert alert-success">
    <h4>Process movie return</h4>
</div>

<div class="card">
    <div class="card-header bg-success text-white">
        <h3>Rental Details</h3>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Movie:</dt>
            <dd class="col-sm-9">@Model.Movie.Title</dd>

            <dt class="col-sm-3">Customer:</dt>
            <dd class="col-sm-9">@Model.Customer.FirstName @Model.Customer.LastName</dd>

            <dt class="col-sm-3">Rental Date:</dt>
            <dd class="col-sm-9">@Model.RentalDate.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Return Date:</dt>
            <dd class="col-sm-9">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Days Rented:</dt>
            <dd class="col-sm-9"><strong>@days day(s)</strong></dd>

            <dt class="col-sm-3">Price per Day:</dt>
            <dd class="col-sm-9">@Model.Movie.PricePerDay.ToString("C")</dd>

            <dt class="col-sm-3">Estimated Total:</dt>
            <dd class="col-sm-9"><strong class="text-success">@estimatedPrice.ToString("C")</strong></dd>
        </dl>
    </div>
</div>

<form asp-action="Return" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-success btn-lg">
        Confirm Return - @estimatedPrice.ToString("C")
    </button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>