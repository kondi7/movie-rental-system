@model IEnumerable<MovieRentalSystem.Models.Rental>

@{
    ViewData["Title"] = "Rentals";
}

<div class="row mb-3">
    <div class="col-md-6">
        <h1>Rentals</h1>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-primary">
            Add New Rental
        </a>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <input type="text" id="searchBox" class="form-control" placeholder="Search rentals...">
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-3">
        <button class="btn btn-outline-secondary" onclick="filterRentals('all')">All</button>
        <button class="btn btn-outline-warning" onclick="filterRentals('active')">Active</button>
        <button class="btn btn-outline-success" onclick="filterRentals('returned')">Returned</button>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover" id="rentalsTable">
        <thead class="table-dark">
            <tr>
                <th>Movie</th>
                <th>Customer</th>
                <th>Rental Date</th>
                <th>Return Date</th>
                <th>Total Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="rental-row" data-status="@(item.IsReturned ? "returned" : "active")">
                    <td>@item.Movie.Title</td>
                    <td>@item.Customer.FirstName @item.Customer.LastName</td>
                    <td>@item.RentalDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (item.ReturnDate.HasValue)
                        {
                            @item.ReturnDate.Value.ToString("dd/MM/yyyy")
                        }
                        else
                        {
                            <span class="text-muted">Not returned</span>
                        }
                    </td>
                    <td>@item.TotalPrice.ToString("C")</td>
                    <td>
                        @if (item.IsReturned)
                        {
                            <span class="badge bg-success">Returned</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Active</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        @if (!item.IsReturned)
                        {
                            <a asp-action="Return" asp-route-id="@item.Id" class="btn btn-sm btn-success">Return</a>
                        }
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function filterRentals(status) {
            const rows = document.querySelectorAll('.rental-row');
            rows.forEach(row => {
                if (status === 'all') {
                    row.classList.remove('d-none');
                } else {
                    if (row.dataset.status === status) {
                        row.classList.remove('d-none');
                    } else {
                        row.classList.add('d-none');//display none
                    }
                }
            });
        }

        setupSearch('searchBox', 'rentalsTable');
        countItems('Rentals');
    </script>
}