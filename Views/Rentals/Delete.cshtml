@model MovieRentalSystem.Models.Rental

@{
    ViewData["Title"] = "Delete Rental";
}

<h1>Delete Rental</h1>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this rental record?</h4>
</div>

<div class="card">
    <div class="card-header bg-danger text-white">
        <h3>Rental Information</h3>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Movie:</dt>
            <dd class="col-sm-9">@Model.Movie.Title</dd>

            <dt class="col-sm-3">Customer:</dt>
            <dd class="col-sm-9">@Model.Customer.FirstName @Model.Customer.LastName</dd>

            <dt class="col-sm-3">Rental Date:</dt>
            <dd class="col-sm-9">@Model.RentalDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Status:</dt>
            <dd class="col-sm-9">
                @if (Model.IsReturned)
                {
                    <span class="badge bg-success">Returned</span>
                }
                else
                {
                    <span class="badge bg-warning">Active</span>
                }
            </dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you absolutely sure?')">
        Confirm Delete
    </button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>