@model IEnumerable<MovieRentalSystem.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<div class="row mb-3">
    <div class="col-md-6">
        <h1>Customers</h1>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-primary">
            Add New Customer
        </a>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <input type="text" id="searchBox" class="form-control" placeholder="Search customers...">
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover" id="customersTable">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Registered</th>
                <th>Total Rentals</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FirstName @item.LastName</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>@item.RegisteredDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        <span class="badge bg-primary">@item.Rentals.Count</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        setupSearch('searchBox', 'customersTable');
        countItems('Customers');
    </script>
}